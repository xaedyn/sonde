{
  "name": "chronoscope",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "Shane Wyatt",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm run typecheck:functions",
    "typecheck:functions": "tsc -p functions/tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "smoke:live": "node scripts/smoke-live-site.cjs",
    "companion": "node companion/local-agent.cjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name chronoscope"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/workers-types": "^4.20260509.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.7",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
